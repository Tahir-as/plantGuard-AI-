rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "meertahirbaloch12@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'];
    }

    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'diseaseName', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.imageUrl is string &&
             data.diseaseName is string;
    }

    function isValidDisease(data) {
      return data.keys().hasAll(['name', 'plantType', 'treatment']) &&
             data.name is string &&
             data.plantType is string &&
             data.treatment is string;
    }

    // Rules
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (isAdmin() || request.resource.data.role == resource.data.role);
    }
    
    match /scans/{scanId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidScan(request.resource.data);
      allow update, delete: if isAdmin();
    }
    
    match /diseases/{diseaseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidDisease(request.resource.data);
    }
  }
}
